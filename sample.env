# --- Server mode (default): WebUI + internal scheduler ---
SECRET_KEY=change_me_to_a_long_random_string
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me
SLEEPERSTACK_DB_PATH=/data/sleeperstack.db

# --- One-shot mode (MODE=oneshot): legacy single-run CLI behavior ---
MODE=oneshot
PORTAINER_URL=http://host.docker.internal:9000/api
PORTAINER_API_KEY=your_real_api_key
PORTAINER_ENDPOINT_ID=1
TARGET_LABEL=autoshutdown=true
ACTION=stop
